<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>404</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    height:100vh;
    margin:0;
    overflow:hidden;
    background: radial-gradient(circle at top, #111 0%, #000 100%);
    display:flex;
    justify-content:center;
    align-items:center;
    color:#fff;
    font-family: 'Segoe UI', sans-serif;
}

.container-box{
    text-align:center;
    z-index:2;
    animation: fadeUp 1.2s ease;
}

h1{
    font-size:7rem;
    font-weight:900;
    letter-spacing:5px;
    background: linear-gradient(90deg,#00f2fe,#4facfe);
    -webkit-background-clip:text;
    color:transparent;
    animation: glow 0.5s infinite alternate;
}

p{
    font-size:1.2rem;
    color:rgba(255,255,255,0.7);
    margin-bottom:25px;
}

.btn-home{
    padding:12px 28px;
    border-radius:30px;
    border:none;
    font-weight:bolder;
    background: linear-gradient(90deg,#00f2fe,#4facfe);
    color:#000;
    transition: all 0.3s ease;
}

.btn-home:hover{
    transform: translateY(-1px) scale(1.05);
    box-shadow:0 5px 30px rgba(0,242,254,0.5);
    color:#000;
}

.stars{
    position:absolute;
    width:100%;
    height:100%;
    background: transparent;
}

.stars span{
    position:absolute;
    width:2px;
    height:2px;
    background:white;
    animation: moveStars linear infinite;
}

.stars span:nth-child(1){ top:10%; left:20%; animation-duration:5s;}
.stars span:nth-child(2){ top:40%; left:70%; animation-duration:8s;}
.stars span:nth-child(3){ top:80%; left:30%; animation-duration:6s;}
.stars span:nth-child(4){ top:60%; left:10%; animation-duration:7s;}
.stars span:nth-child(5){ top:20%; left:90%; animation-duration:9s;}
.stars span:nth-child(6){ top:10%; left:30%; animation-duration:7s;}
.stars span:nth-child(7){ top:50%; left:30%; animation-duration:8s;}
.stars span:nth-child(8){ top:70%; left:80%; animation-duration:6s;}
.stars span:nth-child(9){ top:40%; left:60%; animation-duration:5s;}
.stars span:nth-child(10){ top:50%; left:80%; animation-duration:10s;}

.planet{
    position:absolute;
    width:140px;
    bottom:10%;
    left:10%;
    animation: float 6s infinite ease-in-out;
}

a{
    text-decoration: none;
}

@keyframes moveStars{
    0%{ transform: translateY(0); opacity:1;}
    50%{transform: translateY(50vh); opacity:0;}
    75%{ transform: translateY(75vh); opacity:1;}
    100%{transform: translateY(100vh); opacity:0;}

}

@keyframes float{
    0%,100%{ transform: translateY(0);}
    50%{ transform: translateY(-20px);}
}

@keyframes fadeUp{
    from{ opacity:0; transform:translateY(30px);}
    to{ opacity:1; transform:translateY(0);}
}

@keyframes glow{
    from{ filter: drop-shadow(0 0 5px #00f2fe);}
    to{ filter: drop-shadow(0 0 20px #4facfe);}
}
</style>
</head>

<body>

<div class="stars">
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
</div>

<div class="container-box">
    <h1>404</h1>
    <p>You’ve drifted into the void.<br>Let’s bring you back.</p>
    <a href="/" class="btn-home">Return Home</a>
</div>

</body>
</html>