<%layout('layouts/boilerplate')%>
<div class="row">
    <h1 class="text-center">Edit Campground</h1>
    <div class="col-md-6 offset-md-3">
        <div class="card shadow">
            <div class="card-body">
                <form action="/campgrounds/<%=camp._id%>?_METHOD=PATCH" method="post" class="validated-form" novalidate enctype="multipart/form-data">
                    
                    <div class="mb-3">
                        <label class="form-label" for="title">Title</label>
                        <input class="form-control" type="text" id="title" name="title" value="<%=camp.title%>" required>
                        <div class="valid-feedback">
                            Looks Good!
                        </div>
                        <div class="invalid-feedback">
                            Title should not be empty
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="location">Location</label>
                        <input class="form-control" type="text" id="location" name="location" value="<%=camp.location%>" required> 
                        <div class="valid-feedback">
                            Looks Good!
                        </div>
                        <div class="invalid-feedback">
                            Location should not be empty
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="price">price</label>
                        <div class="input-group mb-3">
                            <span class="input-group-text">₹</span>
                            <input type="number" class="form-control" aria-label="Amount (to the nearest dollar)" placeholder="0.00" id="price" name="price" value="<%=camp.price%>" required>
                        </div>  
                        <div class="valid-feedback">
                            Looks Good!
                        </div>  
                    </div>
                    
                    <div class="mb-3 custom-file">
                        <label for="image" class="form-label custom-file-label">Add more Images</label>
                        <input class="form-control" type="file" id="image" name="image" multiple>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="description">Description</label>
                        <textarea class="form-control" type="text" id="description" name="description" required ><%=camp.description%></textarea>
                        <div class="valid-feedback">
                            Looks Good!
                        </div>
                        <div class="invalid-feedback">
                            Description should not be empty
                        </div>    
                    </div>
                    <div class="mb-3">
                        <%camp.images.forEach((img,i)=>{%>
                            <img src="<%=img.thumbnail%>" class="img-thumbnail" alt="">
                            <div class="form-check-inline">
                                <input type="checkbox" id="image-<%=i%>" name="deleteImages[]" value="<%=img.filename%>">
                            </div>
                            <label for="image-<%=i%>">Delete</label>
                        <%})%>
                    </div>

                    <button class="btn btn-outline-success mb-3">Update CampGround</button>
                </form>
            <a class="btn btn-outline-info" href="/campgrounds/<%=camp._id%>">Back</a>
            </div>
        </div>
    </div>
</div>